# ---- Database (Postgres + pgvector) ----
# Inside docker compose, services reach the DB at postgres:5432.
# From the host (e.g. `npm run db:push`), use the mapped port 55432.
DATABASE_URL=postgresql://cfm:cfm@localhost:55432/cfm

# ---- App ----
NODE_ENV=development
# Comma-separated allowed origins for CORS / cookies in production
APP_URL=http://localhost:3000

# ---- Auth (JWT in httpOnly cookies) ----
# Generate strong values: `openssl rand -base64 48`
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---- Object storage (S3-compatible) — uploads ----
# Production: Backblaze B2 (endpoint https://s3.<region>.backblazeb2.com,
# keyID/applicationKey). Local dev/tests: the MinIO container from
# docker-compose (started with `docker compose up -d minio`).
S3_ENDPOINT=http://localhost:59000
S3_REGION=us-east-1
S3_BUCKET=cfm-uploads
S3_ACCESS_KEY_ID=cfm
S3_SECRET_ACCESS_KEY=cfm12345

# ---- AI (Phase 6) ----
ANTHROPIC_API_KEY=

# ---- Email (deferred — placeholder seam) ----
# SMTP_URL=
