# ---- Database (Postgres + pgvector) ----
# Inside docker compose, services reach the DB at postgres:5432.
# From the host (e.g. `npm run db:push`), use the mapped port 55432.
DATABASE_URL=postgresql://cfm:cfm@localhost:55432/cfm

# ---- App ----
NODE_ENV=development
# Comma-separated allowed origins for CORS / cookies in production
APP_URL=http://localhost:3000

# ---- Auth (JWT in httpOnly cookies) ----
# Generate strong values: `openssl rand -base64 48`
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---- Backblaze B2 (S3-compatible) — uploads ----
B2_ENDPOINT=https://s3.us-west-000.backblazeb2.com
B2_REGION=us-west-000
B2_BUCKET=sunflower-cfm-uploads
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=

# ---- AI (Phase 6) ----
ANTHROPIC_API_KEY=

# ---- Email (deferred — placeholder seam) ----
# SMTP_URL=
